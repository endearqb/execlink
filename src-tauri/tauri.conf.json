{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ExecLink",
  "version": "0.2.5",
  "identifier": "com.endearqb.execlink",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ExecLink",
        "width": 480,
        "height": 640,
        "minWidth": 360,
        "minHeight": 540,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../src/assets/excelink_symbol_1.ico"
    ],
    "windows": {
      "wix": {
        "template": "wix/main.wxs",
        "language": "zh-CN"
      }
    },
    "resources": [
      "resources/nilesoft.zip"
    ]
  }
}


